            "mov (M1_NM, 1) V0(0,0)<1> COPY14_516_4(0,0)<1;1,0>\n"
            "mov (M1_NM, 1) V0(0,0)<1> COPY15_528_8(0,0)<1;1,0>\n"
            "mov (M1_NM, 1) V0(0,0)<1> COPY16_536_8(0,0)<1;1,0>\n"
            "mov (M1_NM, 1) V0(0,0)<1> COPY17_584_4(0,0)<1;1,0>\n"
            "mov (M1,1) CLOBBER0_588_4(0,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,4) CLOBBER1_592_16(0,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,8) CLOBBER2_608_32(0,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(0,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(2,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(4,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(6,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(8,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(10,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(12,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(14,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(16,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(18,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(20,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(22,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(24,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(26,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(28,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(30,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(32,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER3_640_2304(34,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER4_3968_640(0,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER4_3968_640(2,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER4_3968_640(4,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER4_3968_640(6,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) CLOBBER4_3968_640(8,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) %0(0,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) %0(2,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) %0(4,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) %0(6,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) %1(0,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) %1(2,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) %1(4,0)<1> 0xAAAAAAAA:ud\n"
            "mov (M1,32) %1(6,0)<1> 0xAAAAAAAA:ud\n"
            ".decl DUMMY_DPAS_SRC v_type=G type=ud num_elts=128 alias=<CLOBBER3_640_2304,0>\n"
            ".decl DUMMY_DPAS_DST v_type=G type=f num_elts=128 alias=<DUMMY_DPAS_SRC,0>\n"
            "dpas.bf.bf.8.1 (M1,16) DUMMY_DPAS_DST.0 V0.0 DUMMY_DPAS_SRC.0 DUMMY_DPAS_SRC(0,0)\n"
            "fence_sw\n"
            "add (M1,1) CLOBBER0_588_4(0,0)<1> CLOBBER0_588_4(0,0)<0;1,0> 0xfadecaff:ud\n"
            "fence_sw\n"
        "}\n"
    : "=rw"(c.x[0]), "=rw"(c.x[1]) : "rw.u"(a), "rw.u"(lda), "rw.u"(b), "rw.u"(ldb), "rw.u"(m), "rw.u"(n), "rw.u"(k), "rw.u"(i0), "rw.u"(j0), "rw.u"(h0), "rw.u"(local_id_m), "rw.u"(local_id_n), "rw.u"(slm), "rw.u"(a_scale), "rw.u"(a_offset), "rw.u"(ldaq));
    // @_u_@1 
    return c;
}

