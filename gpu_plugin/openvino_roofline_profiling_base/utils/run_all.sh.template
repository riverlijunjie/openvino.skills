#!/bin/bash
# Generic OpenVINO roofline driver (Linux).
#
# This script is MODEL-AGNOSTIC. It sources a companion `run_config.sh` that
# defines the per-model op list, per-platform paths, and iteration budgets.
# Do not edit this file when porting to a new model — edit run_config.sh.
#
# Expected to be run from the directory containing run_config.sh, or with
# RUN_CONFIG=/path/to/run_config.sh in the environment.
#
# Required in run_config.sh:
#   OPENVINO_SETUPVARS   — path to OpenVINO setupvars.sh
#   CLILOADER            — absolute path to cliloader binary
#   BENCH_DIR            — directory containing fc_bench, pa_bench, small_ops_bench
#   RESULTS_DIR          — where per-op logs are written
#   FC_DEC_ITERS, FC_DEC_LM_ITERS, FC_PRE_ITERS
#   PA_DEC_ITERS, PA_PRE_ITERS
#   SM_DEC_ITERS, SM_PRE_ITERS
#   BUFS                 — activation rotation depth (>=4, default 8)
#   FLUSH_MB             — cache-flush kernel size in MB (default 64)
#   FC_CONFIGS           — bash array of "M K N TAG prec iters" entries
#   PA_CONFIGS           — bash array of "mode M kv iters TAG kv_dtype" entries
#   SM_CONFIGS           — bash array of "TAG iters op shape_args..." entries
#
# See run_all.sh.example for a fully populated reference (Qwen3-8B).

set -e

RUN_CONFIG="${RUN_CONFIG:-./run_config.sh}"
if [[ ! -f "$RUN_CONFIG" ]]; then
  echo "error: $RUN_CONFIG not found. Copy run_config.sh.example and customize." >&2
  exit 1
fi
# shellcheck disable=SC1090
source "$RUN_CONFIG"

# shellcheck disable=SC1090
source "$OPENVINO_SETUPVARS"

mkdir -p "$RESULTS_DIR"
export CLI_DevicePerformanceTiming=1
export CLI_DevicePerformanceTimingSkipUnmap=1

: "${BUFS:=8}"
: "${FLUSH_MB:=64}"
: "${WARMUP_FRAC:=5}"

clamp_warmup() {
  local w=$(( $1 / WARMUP_FRAC ))
  (( w < 10 ))  && w=10
  (( w > 500 )) && w=500
  echo "$w"
}

echo "===== FC ====="
for cfg in "${FC_CONFIGS[@]}"; do
  read -r M K N TAG PREC ITERS GROUP <<< "$cfg"
  : "${GROUP:=128}"
  WARMUP=$(clamp_warmup "$ITERS")
  echo "--- FC $TAG M=$M K=$K N=$N g=$GROUP prec=$PREC iters=$ITERS bufs=$BUFS flush=${FLUSH_MB}MB ---"
  "$CLILOADER" "$BENCH_DIR/fc_bench" \
    "$M" "$K" "$N" "$GROUP" "$ITERS" "$WARMUP" "$BUFS" "$PREC" "$FLUSH_MB" \
    2>&1 | tee "$RESULTS_DIR/fc_${TAG}.log"
done

echo "===== PA ====="
PA_BUFS=${PA_BUFS:-4}
for cfg in "${PA_CONFIGS[@]}"; do
  read -r MODE M KV ITERS TAG KV_DTYPE <<< "$cfg"
  : "${KV_DTYPE:=i8}"
  WARMUP=$(clamp_warmup "$ITERS")
  echo "--- PA $MODE $TAG M=$M kv=$KV kv_dtype=$KV_DTYPE iters=$ITERS ---"
  "$CLILOADER" "$BENCH_DIR/pa_bench" \
    "$MODE" "$M" "$KV" "$ITERS" "$WARMUP" "$PA_BUFS" "$KV_DTYPE" \
    2>&1 | tee "$RESULTS_DIR/pa_${TAG}.log"
done

echo "===== SMALL OPS ====="
for cfg in "${SM_CONFIGS[@]}"; do
  read -r TAG ITERS OP REST <<< "$cfg"
  # The remainder (after TAG ITERS OP) is split as shape args to small_ops_bench.
  WARMUP=$(clamp_warmup "$ITERS")
  echo "--- SmallOp $TAG op=$OP args=$REST iters=$ITERS ---"
  # shellcheck disable=SC2086
  "$CLILOADER" "$BENCH_DIR/small_ops_bench" "$OP" $REST \
    --iters "$ITERS" --warmup "$WARMUP" --bufs "$BUFS" \
    2>&1 | tee "$RESULTS_DIR/sm_${TAG}.log"
done

echo "===== MoE ====="
# MOE_CONFIGS entries: "B S H I NE TK TAG iters [shared_I=0]"
# Use shared_I>0 (e.g. 512) for shared-expert MoE models (Qwen3.5-MoE, DeepSeek-V2/V3).
# moe_bench validates fusion at runtime; the run will fail loudly (exit 2 / 4) if
# the GPU plugin did not collapse the subgraph into moe_3gemm_fused_compressed.
MOE_BUFS=${MOE_BUFS:-4}
for cfg in "${MOE_CONFIGS[@]:-}"; do
  [[ -z "$cfg" ]] && continue
  read -r B S H I NE TK TAG ITERS SHARED_I <<< "$cfg"
  : "${SHARED_I:=0}"
  WARMUP=$(clamp_warmup "$ITERS")
  echo "--- MoE $TAG B=$B S=$S H=$H I=$I NE=$NE TK=$TK shared_I=$SHARED_I iters=$ITERS ---"
  "$CLILOADER" "$BENCH_DIR/moe_bench" \
    "$B" "$S" "$H" "$I" "$NE" "$TK" 128 "$ITERS" "$WARMUP" "$MOE_BUFS" "$FLUSH_MB" "$SHARED_I" \
    2>&1 | tee "$RESULTS_DIR/moe_${TAG}.log"
done

echo "===== ALL DONE ====="
ls "$RESULTS_DIR/" | wc -l
