        </mxCell>
        <mxCell id="e12" value="都 reorder" style="" edge="1" source="s3_r1" target="s3_r2" parent="1"/>

        <mxCell id="s3_r3" value="Rule 3:\nraw_sub_byte\ncompatible?" style="rhombus;whiteSpace=wrap;html=1;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="860" y="780" width="110" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e13" value="都不 reorder\n+ sub-byte" style="" edge="1" source="s3_r1" target="s3_r3" parent="1"/>

        <mxCell id="s3_pass" value="✅ 通过" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1020" y="740" width="80" height="40" as="geometry"/>
        </mxCell>
