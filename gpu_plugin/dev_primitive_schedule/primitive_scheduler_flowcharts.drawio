        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="check_init" parent="1"/>

        <mxCell id="return_early" value="return (已初始化)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="900" y="145" width="150" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="check_init" target="return_early" parent="1"/>

        <!-- Step 1 -->
        <mxCell id="step1_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;dashed=1" vertex="1" parent="1">
          <mxGeometry x="410" y="240" width="580" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="step1_title" value="Step 1: 确定 primary impl type" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="420" y="245" width="250" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="s1_check" value="_impl-&gt;m_manager\n存在?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="430" y="275" width="140" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="s1_yes" value="primary = manager-&gt;\nget_impl_type()" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="610" y="265" width="160" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="s1_no" value="is_onednn? → onednn\nelse → ocl" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="610" y="310" width="160" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="check_init" target="s1_check" parent="1"/>
        <mxCell id="e4" value="Yes" style="" edge="1" source="s1_check" target="s1_yes" parent="1"/>
        <mxCell id="e5" value="No" style="" edge="1" source="s1_check" target="s1_no" parent="1"/>

        <!-- Check GPU native -->
        <mxCell id="check_gpu" value="primary 是 GPU-native?\n(onednn/ocl/sycl/cm)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="600" y="390" width="200" height="80" as="geometry"/>
