        <mxCell id="e10" value="Yes +\nneed retry" style="" edge="1" source="s3_subbyte" target="s3_retry" parent="1"/>

        <mxCell id="s3_r1" value="Rule 1:\nreorder flag\n一致?" style="rhombus;whiteSpace=wrap;html=1;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="720" y="730" width="110" height="60" as="geometry"/>
