        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="step1_box" target="check_gpu" parent="1"/>

        <!-- Step 2 -->
        <mxCell id="step2_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;dashed=1" vertex="1" parent="1">
          <mxGeometry x="410" y="500" width="580" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="step2_title" value="Step 2: 收集候选 impl types (has_impl_for 校验)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="420" y="505" width="400" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="s2_detail" value="for each mgr in m_available_impls:\n   GPU-native? → 未见过? → has_impl_for(node, type, static)?\n   → candidate_types.push_back(type)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="430" y="535" width="540" height="55" as="geometry"/>
