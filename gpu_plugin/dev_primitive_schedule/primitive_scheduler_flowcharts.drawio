        <mxCell id="e11" style="" edge="1" source="s3_retry" target="s3_r1" parent="1"/>
        <mxCell id="e11b" value="No" style="" edge="1" source="s3_subbyte" target="s3_r1" parent="1"/>

        <mxCell id="s3_r2" value="Rule 2:\nsource layout\n一致?" style="rhombus;whiteSpace=wrap;html=1;fontSize=10" vertex="1" parent="1">
