        <mxCell id="step3_title" value="Step 3: 逐候选编译 + Weight IO Contract 检查" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1" vertex="1" parent="1">
