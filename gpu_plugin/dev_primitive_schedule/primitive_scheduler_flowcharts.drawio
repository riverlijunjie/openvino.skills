        <mxCell id="s3_subbyte" value="sub-byte weight\n&amp;&amp; t ≠ primary?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10" vertex="1" parent="1">
