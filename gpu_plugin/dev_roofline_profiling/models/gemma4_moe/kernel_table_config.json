{
  "title": "f'# {model_name} — Per-token-size Kernel Tables'",
  "variables": {
    "NL_S": "cfg['num_sliding_attention_layers']",
    "NL_F": "cfg['num_full_attention_layers']",
    "NL": "cfg['num_hidden_layers']",
    "H": "cfg['hidden_size']",
    "NH": "cfg['num_attention_heads']",
    "NKV_S": "cfg['num_key_value_heads_sliding']",
    "NKV_F": "cfg['num_global_key_value_heads']",
    "HD_S": "cfg['head_dim_sliding']",
    "HD_F": "cfg['head_dim_full']",
    "I_DENSE": "cfg['intermediate_size']",
    "I_MOE": "cfg['moe_intermediate_size']",
    "NE": "cfg['num_experts']",
    "TK": "cfg['top_k_experts']",
    "VOCAB": "cfg['vocab_size']"
  },
  "modes": [
    {
      "name": "decode",
      "heading": "'### DECODE — per kv (M=1)'",
      "axis_name": "kv",
      "axis_label": "kv",
      "axis_values": [1024, 2048, 4096, 8192, 16384, 32768, 65536, 131072],
      "peak_compute": "platform.get('fp16_xmx_tflops', 0) * 1000",
      "specs": [
        {"op": "'moe_3gemm_fused'", "log": "'moe_decode_M1'", "calls": "NL",
         "bytes": "TK*(3*H*I_MOE//2 + 3*max(1,H//64)*I_MOE*2 + 3*max(1,H//64)*I_MOE//2) + (H + TK*I_MOE*2)*2",
         "flops": "TK*3*H*I_MOE*2", "bound": "'memory'"},
        {"op": "'dense_mlp_gate'", "log": "'fc_mlp_gate_decode_M1'", "calls": "NL",
         "bytes": "fc_bytes_int4(1, H, I_DENSE, 128)", "flops": "fc_flops(1, H, I_DENSE)", "bound": "'memory'"},
        {"op": "'dense_mlp_up (=gate shape)'", "log": "'fc_mlp_gate_decode_M1'", "calls": "NL",
         "bytes": "fc_bytes_int4(1, H, I_DENSE, 128)", "flops": "fc_flops(1, H, I_DENSE)", "bound": "'memory'"},
        {"op": "'dense_mlp_down'", "log": "'fc_mlp_down_decode_M1'", "calls": "NL",
         "bytes": "fc_bytes_int4(1, I_DENSE, H, 64)", "flops": "fc_flops(1, I_DENSE, H)", "bound": "'memory'"},
        {"op": "'fc_qkv_sliding'", "log": "'fc_qkv_sliding_decode_M1'", "calls": "NL_S",
         "bytes": "fc_bytes_int4(1, H, NH*HD_S+NKV_S*HD_S*2, 128)", "flops": "fc_flops(1, H, NH*HD_S+NKV_S*HD_S*2)", "bound": "'memory'"},
        {"op": "'fc_o_sliding'", "log": "'fc_o_sliding_decode_M1'", "calls": "NL_S",
         "bytes": "fc_bytes_int4(1, NH*HD_S, H, 128)", "flops": "fc_flops(1, NH*HD_S, H)", "bound": "'memory'"},
        {"op": "'fc_qkv_full (k_eq_v)'", "log": "'fc_qkv_full_decode_M1'", "calls": "NL_F",
         "bytes": "fc_bytes_int4(1, H, NH*HD_F+NKV_F*HD_F, 128)", "flops": "fc_flops(1, H, NH*HD_F+NKV_F*HD_F)", "bound": "'memory'"},
        {"op": "'fc_o_full'", "log": "'fc_o_full_decode_M1'", "calls": "NL_F",
         "bytes": "fc_bytes_int4(1, NH*HD_F, H, 128)", "flops": "fc_flops(1, NH*HD_F, H)", "bound": "'memory'"},
        {"op": "'lm_head'", "log": "'lm_head_decode_M1'", "calls": "1",
         "bytes": "fc_bytes_int8(1, H, VOCAB, 128)", "flops": "fc_flops(1, H, VOCAB)", "bound": "'memory'"},
        {"op": "'pa_sliding (kv=1024 fixed)'", "log": "'pa_sliding_decode_kv1024'", "calls": "NL_S",
         "bytes": "2*NKV_S*HD_S*1024", "flops": "2*NH*HD_S*1024*2", "bound": "'memory'"},
        {"op": "'pa_full'", "log": "f'pa_full_decode_kv{kv}'", "calls": "NL_F",
         "bytes": "2*NKV_F*HD_F*kv", "flops": "2*NH*HD_F*kv*2", "bound": "'memory'"},
        {"op": "'rmsnorm'", "log": "'so_rmsnorm_h2816_decode'", "calls": "7*NL",
         "bytes": "H*4", "flops": "H*8", "bound": "'memory'"},
        {"op": "'add'", "log": "'so_add_h2816_decode'", "calls": "2*NL",
         "bytes": "H*6", "flops": "H", "bound": "'memory'"},
        {"op": "'q_norm_sliding'", "log": "'so_rmsnorm3d_qnorm_sliding'", "calls": "NL_S",
         "bytes": "NH*HD_S*4", "flops": "NH*HD_S*8", "bound": "'memory'"},
        {"op": "'k_norm_sliding'", "log": "'so_rmsnorm3d_knorm_sliding'", "calls": "NL_S",
         "bytes": "NKV_S*HD_S*4", "flops": "NKV_S*HD_S*8", "bound": "'memory'"},
        {"op": "'v_norm_sliding'", "log": "'so_rmsnorm3d_vnorm_sliding'", "calls": "NL_S",
         "bytes": "NKV_S*HD_S*4", "flops": "NKV_S*HD_S*8", "bound": "'memory'"},
        {"op": "'rope_q_sliding'", "log": "'so_rope_q_sliding_decode'", "calls": "NL_S",
         "bytes": "NH*HD_S*4", "flops": "NH*HD_S*10", "bound": "'memory'"},
        {"op": "'rope_k_sliding'", "log": "'so_rope_k_sliding_decode'", "calls": "NL_S",
         "bytes": "NKV_S*HD_S*4", "flops": "NKV_S*HD_S*10", "bound": "'memory'"}
      ]
    },
    {
      "name": "prefill",
      "heading": "f\"### PREFILL — per S (compute-bound uses INT8 XMX peak = {platform.get('int8_xmx_tops', 0):.1f} TOPS)\"",
      "axis_name": "S",
      "axis_label": "S",
      "axis_values": [1024, 2048, 4096, 8192],
      "peak_compute": "platform.get('int8_xmx_tops', 0) * 1000",
      "specs": [
        {"op": "'moe_3gemm_fused'", "log": "f'moe_prefill_S{S}'", "calls": "NL",
         "bytes": "3*H*I_MOE*NE//2 + S*TK*(3*H + 3*I_MOE)*2",
         "flops": "S*TK*3*H*I_MOE*2", "bound": "'compute'",
         "ignore_kernel_patterns": ["'^reorder_data'"]},
        {"op": "'dense_mlp_gate'", "log": "f'fc_mlp_gate_prefill_S{S}'", "calls": "NL",
         "bytes": "fc_bytes_int8(S, H, I_DENSE, 128)", "flops": "fc_flops(S, H, I_DENSE)", "bound": "'compute'"},
        {"op": "'dense_mlp_down'", "log": "f'fc_mlp_down_prefill_S{S}'", "calls": "NL",
         "bytes": "fc_bytes_int8(S, I_DENSE, H, 64)", "flops": "fc_flops(S, I_DENSE, H)", "bound": "'compute'"},
        {"op": "'fc_qkv_sliding'", "log": "f'fc_qkv_sliding_prefill_S{S}'", "calls": "NL_S",
         "bytes": "fc_bytes_int8(S, H, NH*HD_S+NKV_S*HD_S*2, 128)", "flops": "fc_flops(S, H, NH*HD_S+NKV_S*HD_S*2)", "bound": "'compute'"},
        {"op": "'fc_o_sliding'", "log": "f'fc_o_sliding_prefill_S{S}'", "calls": "NL_S",
         "bytes": "fc_bytes_int8(S, NH*HD_S, H, 128)", "flops": "fc_flops(S, NH*HD_S, H)", "bound": "'compute'"},
        {"op": "'fc_qkv_full'", "log": "f'fc_qkv_full_prefill_S{S}'", "calls": "NL_F",
         "bytes": "fc_bytes_int8(S, H, NH*HD_F+NKV_F*HD_F, 128)", "flops": "fc_flops(S, H, NH*HD_F+NKV_F*HD_F)", "bound": "'compute'"},
        {"op": "'fc_o_full'", "log": "f'fc_o_full_prefill_S{S}'", "calls": "NL_F",
         "bytes": "fc_bytes_int8(S, NH*HD_F, H, 128)", "flops": "fc_flops(S, NH*HD_F, H)", "bound": "'compute'"},
        {"op": "'pa_sliding'", "log": "f'pa_sliding_prefill_S{S}'", "calls": "NL_S",
         "bytes": "4*S*NH*HD_S*2", "flops": "2*S*(S+1)//2*NH*HD_S*4", "bound": "'compute'"},
        {"op": "'pa_full'", "log": "f'pa_full_prefill_S{S}'", "calls": "NL_F",
         "bytes": "4*S*NH*HD_F*2", "flops": "2*S*(S+1)//2*NH*HD_F*4", "bound": "'compute'"},
        {"op": "'rmsnorm'", "log": "f'so_rmsnorm_h2816_prefill_S{S}'", "calls": "7*NL",
         "bytes": "S*H*4", "flops": "S*H*8", "bound": "'memory'"},
        {"op": "'rope_q_sliding'", "log": "f'so_rope_q_sliding_prefill_S{S}'", "calls": "NL_S",
         "bytes": "S*NH*HD_S*4", "flops": "S*NH*HD_S*10", "bound": "'memory'"}
      ]
    }
  ]
}
