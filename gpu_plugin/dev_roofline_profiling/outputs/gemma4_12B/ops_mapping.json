{
  "model": "google/gemma-4-12B-it (Gemma4 dense, text only)",
  "platform": "PTL 12Xe (Intel Arc B390 96CUs @ 2400 MHz, treated as PTL Xe3)",
  "config": {
    "hidden_size": 3840,
    "num_hidden_layers": 48,
    "layer_pattern": "5:1 sliding:full (positions 5,11,17,23,29,35,41,47 are full) => 40 sliding + 8 full",
    "num_attention_heads": 16,
    "num_key_value_heads": 8,
    "num_global_key_value_heads": 1,
    "head_dim": 256,
    "global_head_dim": 512,
    "intermediate_size": 15360,
    "moe_intermediate_size": null,
    "num_experts": null,
    "enable_moe_block": false,
    "hidden_activation": "gelu_pytorch_tanh",
    "sliding_window": 1024,
    "attention_k_eq_v": true,
    "tie_word_embeddings": true,
    "final_logit_softcapping": 30.0,
    "vocab_size": 262144,
    "max_position_embeddings": 262144,
    "rope": {
      "sliding_attention": {"rope_type": "default", "rope_theta": 10000.0},
      "full_attention": {"rope_type": "proportional", "rope_theta": 1000000.0, "partial_rotary_factor": 0.25}
    },
    "weight_quant_body": "INT4 g=128 (asymmetric)",
    "weight_quant_lm_head": "INT8 g=128",
    "kv_cache_quant": "INT8",
    "activation_dtype": "FP16"
  },
  "attention_shapes": {
    "sliding": {
      "NH": 16, "NKV": 8, "HD": 256,
      "Q_dim": 4096, "K_dim": 2048, "V_dim": 2048,
      "QKV_fused_N": 8192,
      "O_K": 4096, "O_N": 3840,
      "comment": "Q=NH*HD=4096, K=V=NKV*HD=2048, QKV=Q+K+V=8192"
    },
    "full": {
      "NH": 16, "NKV": 1, "HD": 512,
      "Q_dim": 8192, "K_dim": 512, "V_dim": 512,
      "QK_fused_N": 8704,
      "O_K": 8192, "O_N": 3840,
      "comment": "Q=NH*HD=8192, K=NKV*HD=512, V=K (attention_k_eq_v=true), QK=Q+K=8704"
    }
  },
  "input_token_sizes": [512, 912, 1024, 4096],
  "sdpa_impl": "PagedAttention OpenCL + micro_kernel (kv_type=i8)",
  "ops": [
    {
      "op": "embedding",
      "kernel": "gather",
      "shape": "[vocab=262144, H=3840] tied with LM_head",
      "calls_per_inference": 1,
      "notes": "Tied with LM_head INT8"
    },
    {
      "op": "FC_QKV_sliding",
      "kernel": "FullyConnectedCompressed (decode: gemm_kernel, prefill: dq+gemm_kernel)",
      "shape": "K=3840, N=8192, INT4 g=128",
      "calls_per_inference": 40,
      "fused": "Q+K+V projections fused into one GEMM (8192=4096+2048+2048)"
    },
    {
      "op": "FC_O_sliding",
      "kernel": "FullyConnectedCompressed",
      "shape": "K=4096, N=3840, INT4 g=128",
      "calls_per_inference": 40
    },
    {
      "op": "FC_QK_full",
      "kernel": "FullyConnectedCompressed",
      "shape": "K=3840, N=8704, INT4 g=128",
      "calls_per_inference": 8,
      "fused": "Q+K fused (V reuses K projection due to attention_k_eq_v=true), 8704=8192+512"
    },
    {
      "op": "FC_O_full",
      "kernel": "FullyConnectedCompressed",
      "shape": "K=8192, N=3840, INT4 g=128",
      "calls_per_inference": 8
    },
    {
      "op": "FC_Gate_dense",
      "kernel": "FullyConnectedCompressed",
      "shape": "K=3840, N=15360, INT4 g=128",
      "calls_per_inference": 48,
      "notes": "GEGLU MLP gate projection"
    },
    {
      "op": "FC_Up_dense",
      "kernel": "FullyConnectedCompressed",
      "shape": "K=3840, N=15360, INT4 g=128",
      "calls_per_inference": 48,
      "notes": "GEGLU MLP up projection"
    },
    {
      "op": "FC_Down_dense",
      "kernel": "FullyConnectedCompressed",
      "shape": "K=15360, N=3840, INT4 g=128",
      "calls_per_inference": 48,
      "notes": "GEGLU MLP down projection"
    },
    {
      "op": "LM_head",
      "kernel": "FullyConnectedCompressed (gemm_kernel)",
      "shape": "M=1, K=3840, N=262144, INT8 g=128",
      "calls_per_inference": 1,
      "notes": "Single output token, used for both decode and prefill"
    },
    {
      "op": "PA_sliding",
      "kernel": "PagedAttention (paged_attn_single_token / sdpa_micro_prefill)",
      "shape": "NH=16, NKV=8, HD=256, sliding_window=1024, KV=INT8",
      "calls_per_inference": 40,
      "notes": "Sliding-window attention, KV capped at min(ctx,1024)"
    },
    {
      "op": "PA_full",
      "kernel": "PagedAttention (paged_attn_single_token / sdpa_micro_prefill)",
      "shape": "NH=16, NKV=1, HD=512, KV=INT8",
      "calls_per_inference": 8,
      "notes": "Full causal attention, partial_rotary_factor=0.25"
    },
    {
      "op": "rmsnorm_hidden",
      "kernel": "RMSNorm",
      "shape": "[M, H=3840]",
      "calls_per_inference": "4*48 + 1 = 193",
      "notes": "pre-attn + post-attn + pre-mlp + post-mlp + final RMSNorm"
    },
    {
      "op": "rmsnorm3d_q_sliding",
      "kernel": "RMSNorm",
      "shape": "[M, NH=16, HD=256]",
      "calls_per_inference": 40
    },
    {
      "op": "rmsnorm3d_k_sliding",
      "kernel": "RMSNorm",
      "shape": "[M, NKV=8, HD=256]",
      "calls_per_inference": 40
    },
    {
      "op": "rmsnorm3d_q_full",
      "kernel": "RMSNorm",
      "shape": "[M, NH=16, HD=512]",
      "calls_per_inference": 8
    },
    {
      "op": "rmsnorm3d_k_full",
      "kernel": "RMSNorm",
      "shape": "[M, NKV=1, HD=512]",
      "calls_per_inference": 8
    },
    {
      "op": "rope_q_sliding",
      "kernel": "RoPE (element-wise)",
      "shape": "[1, M, NH=16, HD=256]",
      "calls_per_inference": 40
    },
    {
      "op": "rope_k_sliding",
      "kernel": "RoPE",
      "shape": "[1, M, NKV=8, HD=256]",
      "calls_per_inference": 40
    },
    {
      "op": "rope_q_full",
      "kernel": "RoPE",
      "shape": "[1, M, NH=16, HD=512]",
      "calls_per_inference": 8,
      "notes": "partial_rotary_factor=0.25; bench measures full HD (slight over-estimate)"
    },
    {
      "op": "rope_k_full",
      "kernel": "RoPE",
      "shape": "[1, M, NKV=1, HD=512]",
      "calls_per_inference": 8
    },
    {
      "op": "add_residual",
      "kernel": "eltwise Add",
      "shape": "[M, H=3840]",
      "calls_per_inference": "2*48 = 96",
      "notes": "Residual after attention and after MLP"
    },
    {
      "op": "GEGLU_multiply",
      "kernel": "SwiGLU primitive (fused gelu(gate)*up)",
      "shape": "[M, intermediate=15360]",
      "fused": true,
      "notes": "Fused into MLP pipeline; not measured standalone"
    }
  ]
}
