    "paged_attention_full":
      { "config": "NH=16, NKV=2, HD=256, GQA=8, kv_int8, RoPE applies on 25% of head_dim", "calls_per_decode": 12 },
    "linattn_input_proj":
      { "shape": "FC(M, 2048, 12288)", "weight": "INT4 g=128", "calls_per_decode": 36,
