    "gated_delta_net":
      { "config": "HK=32, K=V=128, kernel=GatedDeltaNet (gdn_bench)", "calls_per_decode": 36 },
    "moe_3gemm_fused":
      { "config": "H=2048, I=512, NE=512, TK=10, +shared_I=512", "calls_per_decode": 48,
        "note": "with always-on shared expert (additional dense gate/up/down with I=512); routed top-K=10 experts out of 512" },
    "lm_head":
      { "shape": "FC(1, 2048, 151936)", "weight": "INT8 g=128", "calls_per_decode": 1 },
    "small_ops_per_layer":
